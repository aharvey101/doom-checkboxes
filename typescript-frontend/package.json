{
  "name": "spacetimedb-typescript-checkboxes",
  "version": "1.0.0",
  "description": "TypeScript frontend for SpacetimeDB collaborative checkboxes",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "vite --host --port 8080",
    "generate": "spacetime generate --lang typescript --out-dir ./src/generated --module-path ../backend",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ci": "TEST_ENV=ci vitest run",
    "test:e2e": "cd .. && npx playwright test --project=ci",
    "test:e2e-playwright": "cd .. && npx playwright test --project=ci",
    "test:e2e-staging": "cd .. && npx playwright test --project=staging",
    "test:e2e-production": "cd .. && npx playwright test --project=production",
    "test:e2e-ui": "cd .. && npx playwright test --ui",
    "test:e2e-headed": "cd .. && npx playwright test --headed",
    "test:e2e-debug": "cd .. && npx playwright test --debug",
    "test:integration": "cd .. && npx playwright test *.spec.js",
    "test:setup": "node ../scripts/test-db-manager.js start-local",
    "test:teardown": "node ../scripts/test-db-manager.js stop-local",
    "test:reset": "node ../scripts/test-db-manager.js reset-data",
    "test:full": "npm run test:setup && npm run test:e2e && npm run test:teardown"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-c8": "^0.33.0",
    "c8": "^10.0.0",
    "jsdom": "^29.0.0",
    "playwright": "^1.58.2",
    "typescript": "^5.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "spacetimedb": "^2.0.4"
  },
  "type": "module"
}
