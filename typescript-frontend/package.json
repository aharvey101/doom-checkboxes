{
  "name": "spacetimedb-typescript-checkboxes",
  "version": "1.0.0",
  "description": "TypeScript frontend for SpacetimeDB collaborative checkboxes",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "vite --host --port 8080",
    "generate": "spacetime generate --lang typescript --out-dir ./src/generated --module-path ../backend",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e-ui": "playwright test --ui",
    "test:e2e-headed": "playwright test --headed",
    "test:e2e-debug": "playwright test --debug"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jsdom": "^29.0.0",
    "playwright": "^1.58.2",
    "typescript": "^5.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "spacetimedb": "^2.0.4"
  },
  "type": "module"
}
